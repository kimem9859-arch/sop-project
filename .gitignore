# 가상환경 / 캐시
.poc_venv/
.venv/
__pycache__/
*.pyc

# 시스템 라이브러리 (run.sh가 libGLESv2로 사용)
.syslibs/

# 대용량 데이터 · 출력 · 모델
poc_data/
dev/poc/out/
dev/poc/out2/
dev/poc/out3/
dev/poc/*.task

# 영상: media/ 전부 제외하되 정상 · 스침만 포함
media/*.mp4
!media/overlay_정상.mp4
!media/overlay_스침.mp4

# 로그
*.log
*.err

# 별도 작업·자산 (Rpi5는 별도 깃 저장소)
dev/interlock/ref/
Rpi5/

# 비밀키 (Roboflow API 키 등 — 커밋 금지)
.env
*.env
!*.env.example
dev/ai_model/Dataset_API_Key/

# 학습 산출물·자동 다운로드 가중치 (커밋 불필요)
# - yolov8n/yolo26n.pt = ultralytics가 자동 취득
# - console_v2.pt = train_console_v2.py로 9.6분 재현 가능(seed 고정). 파이 배포물은 .hef(Rpi5 repo)
dev/ai_model/yolov8*.pt
dev/ai_model/yolo26*.pt
dev/ai_model/console_v2.pt
dev/ai_model/runs/
dev/ai_model/console_v2-*/

# DFC 변환 중간산출물 (download_dataset.py + export + cp 로 재현 가능)
dev/ai_model/console_v2.onnx
dev/ai_model/calib_v2/

# 작업로그 훅 temp (세션 시작 HEAD 기록 — SessionEnd가 소비 후 삭제)
.claude/.worklog-head-*
.claude/.startup-sync.tmp

# 윈도우 / OS 정크
*Zone.Identifier
.DS_Store

# Antigravity CLI(agy) 연동 — 자격증명·로컬 환경 (docs/agy-setup-log.md 참조)
gcp-oauth.keys.json
.gdrive-server-credentials.json
.node-env/
.claude/*.local.md
