# 가상환경 / 캐시
.poc_venv/
__pycache__/
*.pyc

# 시스템 라이브러리 (run.sh가 libGLESv2로 사용)
.syslibs/

# 대용량 데이터 · 출력 · 모델
poc_data/
poc/out/
poc/out2/
poc/out3/
poc/*.task

# 영상: 전부 제외하되 정상 · 스침만 포함
poc/*.mp4
!poc/overlay_정상.mp4
!poc/overlay_스침.mp4

# 로그
*.log
*.err

# 별도 작업·자산 (Rpi5는 별도 깃 저장소)
trackA_interlock_ref/
Rpi5/

# 윈도우 / OS 정크
*Zone.Identifier
.DS_Store
